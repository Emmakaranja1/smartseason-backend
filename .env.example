# Database
DATABASE_URL="postgresql://username:password@host:port/database?sslmode=require"

# JWT Secret
JWT_SECRET="your-super-secret-jwt-key-here"

# Server
PORT=3000
NODE_ENV=production

# CORS (comma-separated allowlist)
# Example local: CORS_ORIGINS="http://localhost:5173"
# Example prod:  CORS_ORIGINS="https://your-frontend-domain.com"
CORS_ORIGINS=""
