{
  "info": {
    "name": "SmartSeason API",
    "_postman_id": "smartseason-collection",
    "description": "API collection for SmartSeason Field Monitoring System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000/api"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "field_id",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["auth", "logout"]
            }
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/auth/me",
              "host": ["{{base_url}}"],
              "path": ["auth", "me"]
            }
          }
        }
      ]
    },
    {
      "name": "Users (Admin)",
      "item": [
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Agent One\",\n  \"email\": \"agent@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"FIELD_AGENT\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/users",
              "host": ["{{base_url}}"],
              "path": ["users"]
            }
          }
        },
        {
          "name": "Get Users",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/users",
              "host": ["{{base_url}}"],
              "path": ["users"]
            }
          }
        },
        {
          "name": "Get User by ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/users/2",
              "host": ["{{base_url}}"],
              "path": ["users", "2"]
            }
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/users/2",
              "host": ["{{base_url}}"],
              "path": ["users", "2"]
            }
          }
        }
      ]
    },
    {
      "name": "Fields",
      "item": [
        {
          "name": "Create Field",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Field A\",\n  \"cropType\": \"Maize\",\n  \"plantingDate\": \"2026-04-01\",\n  \"currentStage\": \"PLANTED\",\n  \"assignedAgentId\": 2\n}"
            },
            "url": {
              "raw": "{{base_url}}/fields",
              "host": ["{{base_url}}"],
              "path": ["fields"]
            }
          }
        },
        {
          "name": "Get Fields",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/fields",
              "host": ["{{base_url}}"],
              "path": ["fields"]
            }
          }
        },
        {
          "name": "Get Field by ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/fields/{{field_id}}",
              "host": ["{{base_url}}"],
              "path": ["fields", "{{field_id}}"]
            }
          }
        },
        {
          "name": "Update Field",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentStage\": \"GROWING\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/fields/{{field_id}}",
              "host": ["{{base_url}}"],
              "path": ["fields", "{{field_id}}"]
            }
          }
        },
        {
          "name": "Delete Field",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/fields/{{field_id}}",
              "host": ["{{base_url}}"],
              "path": ["fields", "{{field_id}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Field Updates",
      "item": [
        {
          "name": "Create Field Update",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"stage\": \"GROWING\",\n  \"notes\": \"Crop is healthy\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/fields/{{field_id}}/updates",
              "host": ["{{base_url}}"],
              "path": ["fields", "{{field_id}}", "updates"]
            }
          }
        },
        {
          "name": "Get Field Updates (Admin)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/fields/{{field_id}}/updates",
              "host": ["{{base_url}}"],
              "path": ["fields", "{{field_id}}", "updates"]
            }
          }
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Admin Dashboard",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/dashboard/admin",
              "host": ["{{base_url}}"],
              "path": ["dashboard", "admin"]
            }
          }
        },
        {
          "name": "Agent Dashboard",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/dashboard/agent",
              "host": ["{{base_url}}"],
              "path": ["dashboard", "agent"]
            }
          }
        }
      ]
    }
  ]
}
